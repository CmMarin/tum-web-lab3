        <div class="absolute bottom-[10%] left-[30%] text-[14vw] font-extrabold text-white/[0.04] pointer-events-none select-none font-montserrat uppercase leading-[0.8]">LET'S<br>DANCE</div>
        <div class="contact-container">
            <h2>Ready to Dance?</h2>
            
            <!-- Desktop View -->
            <div class="contact-content desktop-view">
                <div class="contact-info">
                    <h3>Get In Touch</h3>
                    <p><strong>Email:</strong> <a href="mailto:info@vaidoso.com">info@vaidoso.com</a></p>
                    <p><strong>Phone:</strong> <a href="tel:+40741234567">+40 741 234 567</a></p>
                    <p><strong>Instagram:</strong> <a href="https://www.instagram.com/vaidoso.kizomba.school/" target="_blank">@vaidoso.kizomba.school</a></p>
                </div>

                <div class="contact-cta">
                    <p>Sign up for your first free class today!</p>
                    <a href="https://www.instagram.com/vaidoso.kizomba.school/" class="cta-button" target="_blank">Join Us on Instagram</a>
                </div>
            </div>

            <!-- Mobile View: Contact Stack -->
