---
import '../styles/reset.css';
import '../styles/global.css';
import homeData from '../content/home.json';
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Vaidoso Kizomba School - Learn authentic Angolan kizomba dancing with expert instructors. Classes for all levels.">
    <meta name="theme-color" content="#d4165f">
    <link rel="icon" type="image/jpeg" href="/icon-lab.jpg">
    <title>Vaidoso Kizomba School - Authentic Dance Classes</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Open+Sans:wght@300;400;600&display=swap" rel="stylesheet">
</head>
<body>
    <!-- Navigation -->
    <input type="checkbox" id="mobile-menu-check" class="hidden peer">
    <nav class="fixed top-6 left-1/2 -translate-x-1/2 w-[90%] max-w-[1200px] z-[1000] bg-[#141414]/60 backdrop-blur-2xl border border-white/10 rounded-[50px] px-4 md:px-8 py-4 shadow-lg transition-all duration-500 ease-[cubic-bezier(0.2,0.8,0.2,1)] hover:bg-[#191919]/70 hover:border-primary/20 hover:shadow-xl peer-checked:rounded-3xl peer-checked:bg-[#141414]/95 peer-checked:[&_.nav-menu]:flex peer-checked:[&_.nav-menu]:flex-col peer-checked:[&_.nav-menu]:absolute peer-checked:[&_.nav-menu]:top-full peer-checked:[&_.nav-menu]:left-0 peer-checked:[&_.nav-menu]:w-full peer-checked:[&_.nav-menu]:bg-[#141414] peer-checked:[&_.nav-menu]:p-8 peer-checked:[&_.nav-menu]:rounded-b-3xl peer-checked:[&_.nav-menu]:shadow-2xl peer-checked:[&_.nav-menu]:animate-slideDown md:peer-checked:[&_.nav-menu]:flex-row md:peer-checked:[&_.nav-menu]:static md:peer-checked:[&_.nav-menu]:bg-transparent md:peer-checked:[&_.nav-menu]:p-0 md:peer-checked:[&_.nav-menu]:shadow-none peer-checked:[&_.bar:nth-child(1)]:rotate-45 peer-checked:[&_.bar:nth-child(1)]:translate-y-[7px] peer-checked:[&_.bar:nth-child(2)]:opacity-0 peer-checked:[&_.bar:nth-child(3)]:-rotate-45 peer-checked:[&_.bar:nth-child(3)]:-translate-y-[7px]">
        <label for="mobile-menu-check" class="fixed inset-0 bg-black/50 z-[-1] opacity-0 invisible peer-checked:opacity-100 peer-checked:visible transition-all duration-300 md:hidden"></label>
        <div class="w-full flex justify-between items-center relative">
            <div class="text-[1rem] md:text-[1.4rem] font-extrabold uppercase tracking-[2px] bg-clip-text text-transparent bg-gradient-to-r from-primary to-[#ff5e3a]">Vaidoso Kizomba School</div>
            
            <!-- Hamburger Icon -->
            <label for="mobile-menu-check" class="cursor-pointer z-[1001] md:hidden flex flex-col justify-center items-center w-8 h-6 gap-[5px] menu-toggle">
                <div class="bar w-full h-[2px] bg-white rounded-full transition-all duration-300 origin-center"></div>
                <div class="bar w-full h-[2px] bg-white rounded-full transition-all duration-300"></div>
                <div class="bar w-full h-[2px] bg-white rounded-full transition-all duration-300 origin-center"></div>
            </label>

            <ul class="nav-menu hidden md:flex gap-8 items-center">
                <li><a href="#home" class="relative text-white font-semibold text-[0.95rem] tracking-wide transition-colors duration-300 hover:text-primary after:content-[''] after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[2px] after:bg-primary after:transition-all after:duration-300 hover:after:w-full">Home</a></li>
                <li><a href="#about" class="relative text-white font-semibold text-[0.95rem] tracking-wide transition-colors duration-300 hover:text-primary after:content-[''] after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[2px] after:bg-primary after:transition-all after:duration-300 hover:after:w-full">About</a></li>
                <li><a href="#classes" class="relative text-white font-semibold text-[0.95rem] tracking-wide transition-colors duration-300 hover:text-primary after:content-[''] after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[2px] after:bg-primary after:transition-all after:duration-300 hover:after:w-full">Classes</a></li>
                <li><a href="#contact" class="relative text-white font-semibold text-[0.95rem] tracking-wide transition-colors duration-300 hover:text-primary after:content-[''] after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[2px] after:bg-primary after:transition-all after:duration-300 hover:after:w-full">Contact</a></li>
            </ul>
        </div>
    </nav>

    <!-- Hero Section -->
    <section id="home" class="hero">
        <div class="hero-overlay-bottom"></div>
        <div class="hero-content">
            <h1 set:html={homeData.hero_title} />
            <p>{homeData.hero_subtitle}</p>
            <a href={homeData.cta_link} class="cta-button" target="_blank">{homeData.cta_text}</a>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="py-32 relative overflow-hidden">
        <div class="absolute top-[10%] left-[-5%] text-[18vw] font-extrabold text-white/[0.02] pointer-events-none select-none font-montserrat uppercase">PASSION</div>
        <div class="max-w-[1200px] mx-auto px-8">
            <h2 class="text-5xl text-center mb-16 relative inline-block left-1/2 -translate-x-1/2 font-montserrat font-bold after:content-[''] after:block after:w-[60px] after:h-1 after:bg-primary after:mt-4 after:mx-auto after:rounded-sm after:shadow-[0_0_10px_#ff2d55]">About Kizomba</h2>
            
            <!-- Desktop View -->
            <div class="desktop-view">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-16 mb-20">
                    <div class="bg-card p-10 rounded-2xl border border-white/[0.08] transition-transform duration-300 hover:-translate-y-2 hover:border-primary">
                        <h3 class="text-3xl text-primary mb-4 font-montserrat">{homeData.about_title}</h3>
                        <p class="text-muted">{homeData.about_description}</p>
                    </div>
                    
                    <div class="bg-card p-10 rounded-2xl border border-white/[0.08] transition-transform duration-300 hover:-translate-y-2 hover:border-primary">
                        <h3 class="text-3xl text-primary mb-4 font-montserrat">Vaidoso Style</h3>
                        <p class="text-muted">We teach authentic kizomba with focus on proper technique, connection between partners, and musicality. Whether you're a beginner or experienced dancer, you'll find your place in our community.</p>
                    </div>
                </div>

                <div class="bg-card p-12 rounded-[20px] border-[3px] border-transparent relative overflow-hidden" style="background-clip: padding-box, border-box; background-image: linear-gradient(#1e1e1e, #1e1e1e), linear-gradient(135deg, #ff2d55 0%, #ff5e3a 100%);">
                    <h3 class="text-3xl mb-8 text-center font-montserrat">Why Choose Vaidoso?</h3>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
                        <div class="flex items-center gap-4 p-4 bg-white/[0.03] rounded-[10px] transition-colors duration-300 hover:bg-white/[0.06]">
                            <span class="text-primary font-bold text-xl">✓</span>
                            <span>Authentic Angolan technique</span>
                        </div>
                        <div class="flex items-center gap-4 p-4 bg-white/[0.03] rounded-[10px] transition-colors duration-300 hover:bg-white/[0.06]">
                            <span class="text-primary font-bold text-xl">✓</span>
                            <span>Small group classes for personalized attention</span>
                        </div>
                        <div class="flex items-center gap-4 p-4 bg-white/[0.03] rounded-[10px] transition-colors duration-300 hover:bg-white/[0.06]">
                            <span class="text-primary font-bold text-xl">✓</span>
                            <span>Welcoming community for all levels</span>
                        </div>
                        <div class="flex items-center gap-4 p-4 bg-white/[0.03] rounded-[10px] transition-colors duration-300 hover:bg-white/[0.06]">
                            <span class="text-primary font-bold text-xl">✓</span>
                            <span>Regular social dance events</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Mobile View: About & Why Vaidoso Combo Scroller -->
            <div class="mobile-view">
                <div class="mobile-scroll-container">
                    <!-- About Cards -->
                    <div class="mobile-card">
                        <h3>🇦🇴 Origins</h3>
                        <p>Kizomba emerged in Angola in the late 80s. It's a slow, sensual dance blending traditional rhythms with Caribbean vibes.</p>
                    </div>
                    
                    <div class="mobile-card">
                        <h3>✨ Our Style</h3>
                        <p>Authentic technique + Deep connection. We focus on musicality and proper leading/following for all levels.</p>
                    </div>
    
                    <!-- Why Choose Us Cards -->
                    <div class="mobile-card">
                        <span class="mobile-feature-icon">✓</span>
                        <h3>Authentic</h3>
                        <p>Learn the real Angolan technique from day one.</p>
                    </div>

                    <div class="mobile-card">
                        <span class="mobile-feature-icon">👥</span>
                        <h3>Community</h3>
                        <p>Join a welcoming family of passionate dancers.</p>
                    </div>

                    <div class="mobile-card">
                        <span class="mobile-feature-icon">🎉</span>
                        <h3>Events</h3>
                        <p>Regular socials to practice and have fun!</p>
                    </div>
                </div>
            </div>

            <div class="stats">
                <div class="stat">
                    <div class="stat-number">500+</div>
                    <div class="stat-label">Students Trained</div>
                </div>
                <div class="stat">
                    <div class="stat-number">8+</div>
                    <div class="stat-label">Years Experience</div>
                </div>
                <div class="stat">
                    <div class="stat-number">90%</div>
                    <div class="stat-label">Student Satisfaction</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Classes Section -->
    <section id="classes" class="py-32 relative overflow-hidden">
        <div class="absolute top-[20%] left-[80%] text-[10vw] font-extrabold text-white/[0.05] pointer-events-none select-none font-montserrat uppercase">RHYTHM</div>
        <div class="max-w-[1200px] mx-auto px-8">
            <h2 class="text-5xl text-center mb-16 relative inline-block left-1/2 -translate-x-1/2 font-montserrat font-bold after:content-[''] after:block after:w-[60px] after:h-1 after:bg-primary after:mt-4 after:mx-auto after:rounded-sm after:shadow-[0_0_10px_#ff2d55]">Our Classes</h2>
            
            <!-- Desktop View -->
            <div class="desktop-view">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
                <div class="bg-gradient-to-br from-[#1a1a1a] to-[#151515] rounded-[30px] p-14 pb-10 relative border border-white/[0.03] transition-all duration-500 ease-[cubic-bezier(0.2,0.8,0.2,1)] shadow-[0_10px_30px_rgba(0,0,0,0.2)] flex flex-col hover:-translate-y-4 hover:border-primary/30 hover:shadow-[0_25px_50px_rgba(0,0,0,0.4),0_0_30px_rgba(255,45,85,0.05)]">
                    <div class="absolute top-6 right-6 bg-primary/15 text-primary py-2 px-4 rounded-full text-xs font-extrabold uppercase tracking-wider border border-primary/30">First Class Free</div>
                    <h3 class="text-4xl mb-2 text-white tracking-tight font-montserrat">Beginners</h3>
                    <div class="text-secondary mb-8 text-sm">
                        <span class="star">★</span>
                        <span class="star">☆</span>
                        <span class="star">☆</span>
                    </div>
                    <p class="text-primary mb-6 font-bold text-sm uppercase tracking-wide">Monday & Wednesday • 7:00 PM</p>
                    <p class="text-gray-500 mb-auto text-lg leading-relaxed font-light pb-10">New to kizomba? Learn the fundamentals of connection, basic steps, and rhythm. Perfect for dancers of any background.</p>
                    <p class="text-4xl font-extrabold text-white text-left mt-auto tracking-tight drop-shadow-[0_0_20px_rgba(255,255,255,0.1)]">€45/month</p>
                </div>

                <div class="bg-gradient-to-br from-[#1a1a1a] to-[#151515] rounded-[30px] p-14 pb-10 relative border border-white/[0.03] transition-all duration-500 ease-[cubic-bezier(0.2,0.8,0.2,1)] shadow-[0_10px_30px_rgba(0,0,0,0.2)] flex flex-col hover:-translate-y-4 hover:border-primary/30 hover:shadow-[0_25px_50px_rgba(0,0,0,0.4),0_0_30px_rgba(255,45,85,0.05)]">
                    <h3 class="text-4xl mb-2 text-white tracking-tight font-montserrat">Intermediate</h3>
                    <div class="text-secondary mb-8 text-sm">
                        <span class="star">★</span>
                        <span class="star">★</span>
                        <span class="star">☆</span>
                    </div>
                    <p class="text-primary mb-6 font-bold text-sm uppercase tracking-wide">Tuesday & Thursday • 8:00 PM</p>
                    <p class="text-gray-500 mb-auto text-lg leading-relaxed font-light pb-10">Build on your foundations with more complex movements, styling, and partnering techniques. Grow your musicality.</p>
                    <p class="text-4xl font-extrabold text-white text-left mt-auto tracking-tight drop-shadow-[0_0_20px_rgba(255,255,255,0.1)]">€55/month</p>
                </div>

                <div class="bg-gradient-to-br from-[#1a1a1a] to-[#151515] rounded-[30px] p-14 pb-10 relative border border-white/[0.03] transition-all duration-500 ease-[cubic-bezier(0.2,0.8,0.2,1)] shadow-[0_10px_30px_rgba(0,0,0,0.2)] flex flex-col hover:-translate-y-4 hover:border-primary/30 hover:shadow-[0_25px_50px_rgba(0,0,0,0.4),0_0_30px_rgba(255,45,85,0.05)]">
                    <h3 class="text-4xl mb-2 text-white tracking-tight font-montserrat">Advanced</h3>
                    <div class="text-secondary mb-8 text-sm">
                        <span class="star">★</span>
                        <span class="star">★</span>
                        <span class="star">★</span>
                    </div>
                    <p class="text-primary mb-6 font-bold text-sm uppercase tracking-wide">Friday • 8:30 PM</p>
                    <p class="text-gray-500 mb-auto text-lg leading-relaxed font-light pb-10">Master intricate techniques, advanced styling, and leading/following. For experienced dancers seeking to refine their craft.</p>
                    <p class="text-4xl font-extrabold text-white text-left mt-auto tracking-tight drop-shadow-[0_0_20px_rgba(255,255,255,0.1)]">€65/month</p>
                </div>

                <div class="bg-gradient-to-br from-[#1a1a1a] to-[#151515] rounded-[30px] p-14 pb-10 relative border border-white/[0.03] transition-all duration-500 ease-[cubic-bezier(0.2,0.8,0.2,1)] shadow-[0_10px_30px_rgba(0,0,0,0.2)] flex flex-col hover:-translate-y-4 hover:border-primary/30 hover:shadow-[0_25px_50px_rgba(0,0,0,0.4),0_0_30px_rgba(255,45,85,0.05)]">
                    <h3 class="text-4xl mb-2 text-white tracking-tight font-montserrat">Social Nights</h3>
                    <div class="text-secondary mb-8 text-sm">
                        <span class="star">★</span>
                        <span class="star">★</span>
                        <span class="star">☆</span>
                    </div>
                    <p class="text-primary mb-6 font-bold text-sm uppercase tracking-wide">Saturday • 9:00 PM</p>
                    <p class="text-gray-500 mb-auto text-lg leading-relaxed font-light pb-10">Practice what you've learned in a relaxed, social atmosphere. Dance, connect, and enjoy the community.</p>
                    <p class="text-4xl font-extrabold text-white text-left mt-auto tracking-tight drop-shadow-[0_0_20px_rgba(255,255,255,0.1)]">€12/night</p>
                </div>
                </div>
            </div>

            <!-- Mobile View: Classes Scroller -->
            <div class="mobile-view">
                <div class="mobile-scroll-container">
                    <div class="mobile-card mobile-class-card">
                        <h3>Beginners 🌱</h3>
                        <p style="color: var(--primary);">Mon/Wed • 7 PM</p>
                        <p>Start your journey! Learn basics & connection.</p>
                        <h3 style="margin-top: 1rem; color: white;">€45/mo</h3>
                    </div>

                    <div class="mobile-card mobile-class-card">
                        <h3>Intermediate 🚀</h3>
                        <p style="color: var(--primary);">Tue/Thu • 8 PM</p>
                        <p>Level up your moves & musicality.</p>
                        <h3 style="margin-top: 1rem; color: white;">€55/mo</h3>
                    </div>

                    <div class="mobile-card mobile-class-card">
                        <h3>Advanced 🔥</h3>
                        <p style="color: var(--primary);">Fri • 8:30 PM</p>
                        <p>Master intricate styling & leading.</p>
                        <h3 style="margin-top: 1rem; color: white;">€65/mo</h3>
                    </div>

                    <div class="mobile-card mobile-class-card">
                        <h3>Socials 🍹</h3>
                        <p style="color: var(--primary);">Sat • 9 PM</p>
                        <p>Dance, connect & enjoy the vibes!</p>
                        <h3 style="margin-top: 1rem; color: white;">€12/night</h3>
                    </div>
                </div>
            </div>

            <!-- Mobile Only: Class Photos Showcase -->
            <div class="mobile-view mt-12">
                <h3 class="text-2xl text-center mb-6 text-primary font-montserrat">See Our Classes in Action</h3>
                <div class="mobile-scroll-container">
                    <div class="mobile-card mobile-photo-card">
                        <img src="https://images.unsplash.com/photo-1767784097441-217557272ef5?q=80&w=1470&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" alt="Partner dance connection">
                    </div>
                    <div class="mobile-card mobile-photo-card">
                        <img src="https://images.unsplash.com/photo-1767784097087-8c1588215083?q=80&w=1470&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" alt="Dance lesson in studio">
                    </div>
                    <div class="mobile-card mobile-photo-card">
                        <img src="https://images.unsplash.com/photo-1750863773786-52e7d30d6ed9?q=80&w=1528&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" alt="Close partner dancing">
                    </div>
                    <div class="mobile-card mobile-photo-card">
                        <img src="https://images.unsplash.com/photo-1697468502173-606f075e3cac?q=80&w=1632&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" alt="Dance class practice">
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Testimonials Section -->
    <section id="testimonials" class="testimonials">
        <div class="absolute top-[10%] right-[10%] text-[8vw] font-extrabold text-white/[0.15] pointer-events-none select-none font-montserrat uppercase">FAMILY</div>
        <div class="testimonials-container">
            <h2>What Our Students Say</h2>
            
            <!-- Desktop View -->
            <div class="testimonials-grid desktop-view">
                <div class="testimonial-card">
                    <div class="testimonial-header">
                        <div class="stars">★★★★★</div>
                    </div>
                    <p class="testimonial-text">"I came to Vaidoso knowing nothing about kizomba, and now I can't imagine my life without it. The instructors are incredibly patient and the community is so welcoming. Every class feels like a celebration!"</p>
                    <p class="testimonial-author">- Ioana M.</p>
                </div>

                <div class="testimonial-card">
                    <div class="testimonial-header">
                        <div class="stars">★★★★★</div>
                    </div>
                    <p class="testimonial-text">"Finally found a place where I feel comfortable learning to dance. The authentic Angolan technique really makes a difference. Highly recommended for anyone wanting to learn real kizomba!"</p>
                    <p class="testimonial-author">- Mihai C.</p>
                </div>

                <div class="testimonial-card">
                    <div class="testimonial-header">
                        <div class="stars">★★★★★</div>
                    </div>
                    <p class="testimonial-text">"The social nights are amazing! It's the perfect place to practice, meet new dancers, and just enjoy the music. Vaidoso has become my second home. So grateful for this community!"</p>
                    <p class="testimonial-author">- Elena P.</p>
                </div>

                <div class="testimonial-card">
                    <div class="testimonial-header">
                        <div class="stars">★★★★★</div>
                    </div>
                    <p class="testimonial-text">"I took the intermediate class and learned more in one month than I expected. The instructors really care about each student's progress. This is the real deal!"</p>
                    <p class="testimonial-author">- Alexandru B.</p>
                </div>

                <div class="testimonial-card">
                    <div class="testimonial-header">
                        <div class="stars">★★★★★</div>
                    </div>
                    <p class="testimonial-text">"Best decision I made this year. Kizomba at Vaidoso changed not just how I dance, but how I connect with people. Can't recommend it enough!"</p>
                    <p class="testimonial-author">- Andreea G.</p>
                </div>

                <div class="testimonial-card">
                    <div class="testimonial-header">
                        <div class="stars">★★★★★</div>
                    </div>
                    <p class="testimonial-text">"The atmosphere here is special. You can feel the passion for kizomba from everyone involved. The classes are well-structured and the instructors make it fun while being serious about technique."</p>
                    <p class="testimonial-author">- Vlad T.</p>
                </div>
            </div>

            <!-- Mobile View: Testimonials Scroller -->
            <div class="mobile-view">
                <div class="mobile-scroll-container">
                    <div class="mobile-card mobile-testimonial-card">
                        <p>★★★★★</p>
                        <p class="testimonial-text">"Came knowing nothing, now it's my life! Best community ever."</p>
                        <p style="color: white; font-weight: bold;">- Ioana M.</p>
                    </div>

                    <div class="mobile-card mobile-testimonial-card">
                        <p>★★★★★</p>
                        <p class="testimonial-text">"Real authentic technique. Found my dance family here!"</p>
                        <p style="color: white; font-weight: bold;">- Mihai C.</p>
                    </div>

                    <div class="mobile-card mobile-testimonial-card">
                        <p>★★★★★</p>
                        <p class="testimonial-text">"Best decision this year. Changed how I connect with people."</p>
                        <p style="color: white; font-weight: bold;">- Andreea G.</p>
                    </div>
