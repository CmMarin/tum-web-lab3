---
import '../styles/reset.css';
import '../styles/global.css';
import heroData from '../content/home/hero.json';
import aboutData from '../content/home/about.json';
import featuresData from '../content/home/features.json';
import classesData from '../content/home/classes.json';
import testimonialsData from '../content/home/testimonials.json';
import statsData from '../content/home/stats.json';
import faqData from '../content/home/faq.json';
import settingsData from '../content/settings.json';
import mascotData from '../content/mascot.json';

const homeData = {
    hero: heroData,
    about: aboutData,
    features: featuresData,
    classes: classesData,
    testimonials: testimonialsData,
    stats: statsData,
    faq: faqData
};
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content={settingsData.site_description}>
    <meta name="theme-color" content="#d4165f">
    <link rel="icon" type="image/jpeg" href="/icon-lab.jpg">
    <title>{settingsData.site_title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Open+Sans:wght@300;400;600&display=swap" rel="stylesheet">
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script is:inline>
        if (window.netlifyIdentity) {
            window.netlifyIdentity.on("init", user => {
                if (!user) {
                    window.netlifyIdentity.on("login", () => {
                        document.location.href = "/admin/";
                    });
                }
            });
        }
    </script>
</head>
<body>
    <!-- Navigation -->
    <input type="checkbox" id="mobile-menu-check" class="hidden peer">
    <nav class="fixed top-6 left-1/2 -translate-x-1/2 w-[90%] max-w-[1200px] z-[1000] bg-[#141414]/60 backdrop-blur-2xl border border-white/10 rounded-[50px] px-4 md:px-8 py-4 shadow-lg transition-all duration-500 ease-[cubic-bezier(0.2,0.8,0.2,1)] hover:bg-[#191919]/70 hover:border-primary/20 hover:shadow-xl peer-checked:rounded-3xl peer-checked:bg-[#141414]/95 peer-checked:[&_.nav-menu]:flex peer-checked:[&_.nav-menu]:flex-col peer-checked:[&_.nav-menu]:absolute peer-checked:[&_.nav-menu]:top-full peer-checked:[&_.nav-menu]:left-0 peer-checked:[&_.nav-menu]:w-full peer-checked:[&_.nav-menu]:bg-[#141414] peer-checked:[&_.nav-menu]:p-8 peer-checked:[&_.nav-menu]:rounded-b-3xl peer-checked:[&_.nav-menu]:shadow-2xl peer-checked:[&_.nav-menu]:animate-slideDown md:peer-checked:[&_.nav-menu]:flex-row md:peer-checked:[&_.nav-menu]:static md:peer-checked:[&_.nav-menu]:bg-transparent md:peer-checked:[&_.nav-menu]:p-0 md:peer-checked:[&_.nav-menu]:shadow-none peer-checked:[&_.bar:nth-child(1)]:rotate-45 peer-checked:[&_.bar:nth-child(1)]:translate-y-[7px] peer-checked:[&_.bar:nth-child(2)]:opacity-0 peer-checked:[&_.bar:nth-child(3)]:-rotate-45 peer-checked:[&_.bar:nth-child(3)]:-translate-y-[7px]">
        <label for="mobile-menu-check" class="fixed inset-0 bg-black/50 z-[-1] opacity-0 invisible peer-checked:opacity-100 peer-checked:visible transition-all duration-300 md:hidden"></label>
        <div class="w-full flex justify-between items-center relative">
            <div class="text-[1rem] md:text-[1.4rem] font-extrabold uppercase tracking-[2px] bg-clip-text text-transparent bg-gradient-to-r from-primary to-[#ff5e3a]">Vaidoso Kizomba School</div>
            
            <!-- Hamburger Icon -->
            <label for="mobile-menu-check" class="cursor-pointer z-[1001] md:hidden flex flex-col justify-center items-center w-8 h-6 gap-[5px] menu-toggle">
                <div class="bar w-full h-[2px] bg-white rounded-full transition-all duration-300 origin-center"></div>
                <div class="bar w-full h-[2px] bg-white rounded-full transition-all duration-300"></div>
                <div class="bar w-full h-[2px] bg-white rounded-full transition-all duration-300 origin-center"></div>
            </label>

            <ul class="nav-menu hidden md:flex gap-8 items-center">
                <li><a href="#home" class="relative text-white font-semibold text-[0.95rem] tracking-wide transition-colors duration-300 hover:text-primary after:content-[''] after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[2px] after:bg-primary after:transition-all after:duration-300 hover:after:w-full">Home</a></li>
                <li><a href="#about" class="relative text-white font-semibold text-[0.95rem] tracking-wide transition-colors duration-300 hover:text-primary after:content-[''] after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[2px] after:bg-primary after:transition-all after:duration-300 hover:after:w-full">About</a></li>
                <li><a href="#classes" class="relative text-white font-semibold text-[0.95rem] tracking-wide transition-colors duration-300 hover:text-primary after:content-[''] after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[2px] after:bg-primary after:transition-all after:duration-300 hover:after:w-full">Classes</a></li>
                <li><a href="#contact" class="relative text-white font-semibold text-[0.95rem] tracking-wide transition-colors duration-300 hover:text-primary after:content-[''] after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[2px] after:bg-primary after:transition-all after:duration-300 hover:after:w-full">Contact</a></li>
            </ul>
        </div>
    </nav>

    <!-- Hero Section -->
    <section id="home" class="hero" style={`background: linear-gradient(rgba(18,18,18,0.4), #121212), url('${homeData.hero.image}'); background-size: cover; background-position: center; background-attachment: fixed;`}>
        <div class="hero-overlay-bottom"></div>
        <div class="hero-content">
            <h1 set:html={homeData.hero.title} />
            <p>{homeData.hero.subtitle}</p>
            <a href={homeData.hero.cta_link} class="cta-button" target="_blank">{homeData.hero.cta_text}</a>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="py-32 relative overflow-hidden">
        <div class="absolute top-[10%] left-[-5%] text-[18vw] font-extrabold text-white/[0.02] pointer-events-none select-none font-montserrat uppercase">PASSION</div>
        <div class="max-w-[1200px] mx-auto px-8">
            <h2 class="text-5xl text-center mb-16 relative inline-block left-1/2 -translate-x-1/2 font-montserrat font-bold after:content-[''] after:block after:w-[60px] after:h-1 after:bg-primary after:mt-4 after:mx-auto after:rounded-sm after:shadow-[0_0_10px_#ff2d55]">About Kizomba</h2>
            
            <!-- Desktop View -->
            <div class="desktop-view">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-16 mb-20">
                    <div class="bg-card p-10 rounded-2xl border border-white/[0.08] transition-transform duration-300 hover:-translate-y-2 hover:border-primary">
                        <h3 class="text-3xl text-primary mb-4 font-montserrat">{homeData.about.title}</h3>
                        <p class="text-muted">{homeData.about.description}</p>
                    </div>
                    
                    <div class="bg-card p-10 rounded-2xl border border-white/[0.08] transition-transform duration-300 hover:-translate-y-2 hover:border-primary">
                        <h3 class="text-3xl text-primary mb-4 font-montserrat">Vaidoso Style</h3>
                        <p class="text-muted">We teach authentic kizomba with focus on proper technique, connection between partners, and musicality. Whether you're a beginner or experienced dancer, you'll find your place in our community.</p>
                    </div>
                </div>

                <div class="bg-card p-12 rounded-[20px] border-[3px] border-transparent relative overflow-hidden" style="background-clip: padding-box, border-box; background-image: linear-gradient(#1e1e1e, #1e1e1e), linear-gradient(135deg, #ff2d55 0%, #ff5e3a 100%);">
                    <h3 class="text-3xl mb-8 text-center font-montserrat">{homeData.features.title}</h3>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
                        {homeData.features.list.map((feature) => (
                        <div class="flex items-center gap-4 p-4 bg-white/[0.03] rounded-[10px] transition-colors duration-300 hover:bg-white/[0.06]">
                            <span class="text-primary font-bold text-xl">{feature.icon}</span>
                            <span>{feature.text}</span>
                        </div>
                        ))}
                    </div>
                </div>
            </div>

            <!-- Mobile View: About & Why Vaidoso Combo Scroller -->
            <div class="mobile-view">
                <div class="mobile-scroll-container">
                    <!-- About Cards -->
                    <div class="mobile-card">
                        <h3>🇦🇴 Origins</h3>
                        <p>Kizomba emerged in Angola in the late 80s. It's a slow, sensual dance blending traditional rhythms with Caribbean vibes.</p>
                    </div>
                    
                    <div class="mobile-card">
                        <h3>✨ Our Style</h3>
                        <p>Authentic technique + Deep connection. We focus on musicality and proper leading/following for all levels.</p>
                    </div>
    
                    <!-- Why Choose Us Cards -->
                    <div class="mobile-card">
                        <span class="mobile-feature-icon">✓</span>
                        <h3>Authentic</h3>
                        <p>Learn the real Angolan technique from day one.</p>
                    </div>

                    <div class="mobile-card">
                        <span class="mobile-feature-icon">👥</span>
                        <h3>Community</h3>
                        <p>Join a welcoming family of passionate dancers.</p>
                    </div>

                    <div class="mobile-card">
                        <span class="mobile-feature-icon">🎉</span>
                        <h3>Events</h3>
                        <p>Regular socials to practice and have fun!</p>
                    </div>
                </div>
            </div>

            <div class="stats">
                {homeData.stats.list.map((stat) => (
                <div class="stat">
                    <div class="stat-number">{stat.number}</div>
                    <div class="stat-label">{stat.label}</div>
                </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Classes Section -->
    <section id="classes" class="py-32 relative overflow-hidden">
        <div class="absolute top-[20%] left-[80%] text-[10vw] font-extrabold text-white/[0.05] pointer-events-none select-none font-montserrat uppercase">RHYTHM</div>
        <div class="max-w-[1200px] mx-auto px-8">
            <h2 class="text-5xl text-center mb-16 relative inline-block left-1/2 -translate-x-1/2 font-montserrat font-bold after:content-[''] after:block after:w-[60px] after:h-1 after:bg-primary after:mt-4 after:mx-auto after:rounded-sm after:shadow-[0_0_10px_#ff2d55]">{homeData.classes.title}</h2>
            
            <!-- Desktop View -->
            <div class="desktop-view">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
                {homeData.classes.list.map((item) => (
                <div class="bg-gradient-to-br from-[#1a1a1a] to-[#151515] rounded-[30px] p-14 pb-10 relative border border-white/[0.03] transition-all duration-500 ease-[cubic-bezier(0.2,0.8,0.2,1)] shadow-[0_10px_30px_rgba(0,0,0,0.2)] flex flex-col hover:-translate-y-4 hover:border-primary/30 hover:shadow-[0_25px_50px_rgba(0,0,0,0.4),0_0_30px_rgba(255,45,85,0.05)]">
                    {item.is_featured && (
                    <div class="absolute top-6 right-6 bg-primary/15 text-primary py-2 px-4 rounded-full text-xs font-extrabold uppercase tracking-wider border border-primary/30">First Class Free</div>
                    )}
                    <h3 class="text-4xl mb-2 text-white tracking-tight font-montserrat">{item.title}</h3>
                    <div class="text-secondary mb-8 text-sm">
                        {Array.from({ length: 3 }).map((_, i) => (
                           <span class="star">{i < parseInt(item.stars) ? '★' : '☆'}</span> 
                        ))}
                    </div>
                    <p class="text-primary mb-6 font-bold text-sm uppercase tracking-wide">{item.schedule}</p>
                    <p class="text-gray-500 mb-auto text-lg leading-relaxed font-light pb-10">{item.description}</p>
                    <p class="text-4xl font-extrabold text-white text-left mt-auto tracking-tight drop-shadow-[0_0_20px_rgba(255,255,255,0.1)]">{item.price}</p>
                </div>
                ))}
                </div>
            </div>

            <!-- Mobile View: Classes Scroller -->
            <div class="mobile-view">
                <div class="mobile-scroll-container">
                    {homeData.classes.list.map((item) => (
                    <div class="mobile-card mobile-class-card">
                        <h3>{item.title} {item.mobile_icon}</h3>
                        <p style="color: var(--primary);">{item.schedule}</p>
                        <p>{item.description}</p>
                        <h3 style="margin-top: 1rem; color: white;">{item.price}</h3>
                    </div>
                    ))}
                </div>
            </div>

            <!-- Mobile Only: Class Photos Showcase -->
            <div class="mobile-view mt-12">
                <h3 class="text-2xl text-center mb-6 text-primary font-montserrat">See Our Classes in Action</h3>
                <div class="mobile-scroll-container">
                    {homeData.classes.gallery.map((photo) => (
                    <div class="mobile-card mobile-photo-card">
                        <img src={photo.image} alt={photo.alt} />
                    </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- Testimonials Section -->
    <section id="testimonials" class="testimonials">
        <div class="absolute top-[10%] right-[10%] text-[8vw] font-extrabold text-white/[0.15] pointer-events-none select-none font-montserrat uppercase">FAMILY</div>
        <div class="testimonials-container">
            <h2>{homeData.testimonials.title}</h2>
            
            <!-- Desktop View -->
            <div class="testimonials-grid desktop-view">
                {homeData.testimonials.list.map((testimonial) => (
                <div class="testimonial-card">
                    <div class="testimonial-header">
                        <div class="stars">{'★'.repeat(testimonial.rating)}</div>
                    </div>
                    <p class="testimonial-text">"{testimonial.text}"</p>
                    <p class="testimonial-author">- {testimonial.author}</p>
                </div>
                ))}
            </div>

            <!-- Mobile View: Testimonials Scroller -->
            <div class="mobile-view">
                <div class="mobile-scroll-container">
                    {homeData.testimonials.list.map((testimonial) => (
                    <div class="mobile-card mobile-testimonial-card">
                        <p>{'★'.repeat(testimonial.rating)}</p>
                        <p class="testimonial-text">"{testimonial.mobile_text || testimonial.text}"</p>
                        <p style="color: white; font-weight: bold;">- {testimonial.author}</p>
                    </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section id="faq" class="py-20 bg-[#1a1a1a]">
        <div class="max-w-[1000px] mx-auto px-8">
            <h2 class="text-4xl text-center mb-12 font-montserrat font-bold text-white">{homeData.faq.title}</h2>
            <div class="space-y-6">
                {homeData.faq.list.map((item) => (
                    <div class="bg-card p-6 rounded-lg border border-white/[0.05]">
                        <h3 class="text-xl font-bold text-primary mb-2">{item.question}</h3>
                        <p class="text-muted">{item.answer}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="contact">
        <div class="absolute bottom-[10%] left-[30%] text-[14vw] font-extrabold text-white/[0.04] pointer-events-none select-none font-montserrat uppercase leading-[0.8]">LET'S<br>DANCE</div>
        <div class="contact-container">
            <h2>Ready to Dance?</h2>
            
            <!-- Desktop View -->
            <div class="contact-content desktop-view">
                <div class="contact-info">
                    <h3>Get In Touch</h3>
                    <p><strong>Email:</strong> <a href={`mailto:${settingsData.contact_email}`}>{settingsData.contact_email}</a></p>
                    <p><strong>Phone:</strong> <a href={`tel:${settingsData.contact_phone.replace(/[^0-9+]/g, '')}`}>{settingsData.contact_phone}</a></p>
                    <p><strong>Instagram:</strong> <a href={settingsData.instagram_link} target="_blank">@vaidoso.kizomba.school</a></p>
                </div>

                <div class="contact-cta">
                    <p>Sign up for your first free class today!</p>
                    <a href={settingsData.instagram_link} class="cta-button" target="_blank">Join Us on Instagram</a>
                </div>
            </div>

            <!-- Mobile View: Contact Stack -->
            <div class="mobile-view">
                <div class="mobile-scroll-container">
                    <div class="mobile-card mobile-contact-card">
                        <h3>📞 Call Us</h3>
                        <p><a href={`tel:${settingsData.contact_phone.replace(/[^0-9+]/g, '')}`} style="color:white; text-decoration: none;">{settingsData.contact_phone}</a></p>
                    </div>

                    <div class="mobile-card mobile-contact-card">
                        <h3>✉️ Email</h3>
                        <p><a href={`mailto:${settingsData.contact_email}`} style="color:white; text-decoration: none;">{settingsData.contact_email}</a></p>
                    </div>

                    <div class="mobile-card mobile-contact-card">
                        <h3>📸 Instagram</h3>
                        <p><a href={settingsData.instagram_link} target="_blank" style="color:var(--primary); text-decoration: none;">@vaidoso.kizomba.school</a></p>
                    </div>
                </div>
            </div>
            
            <div class="mobile-view" style="text-align: center; margin-top: 2rem;">
                <a href={settingsData.instagram_link} class="cta-button" target="_blank" style="width: 100%;">Sign Up Now!</a>
            </div>
        </div>
    </section>

    <!-- Mascot - "Vibey" The Dancing Note -->
    <div class="mascot-container" title={mascotData.hover_title}>
        <div class="mascot-body">
            <img src="mascot.png" alt="Vibey the Mascot">
        </div>
        <div class="mascot-speech">{mascotData.speech_text}</div>
    </div>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-content">
            <div class="footer-section">
                <h4>Vaidoso Kizomba School</h4>
                <p>Authentic Angolan kizomba dance classes for all levels.</p>
            </div>
            <div class="footer-section">
                <h4>Quick Links</h4>
                <ul>
                    <li><a href="#home">Home</a></li>
                    <li><a href="#about">About</a></li>
                    <li><a href="#classes">Classes</a></li>
                    <li><a href="#contact">Contact</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>Follow Us</h4>
                <p>
                    <a href={settingsData.instagram_link} target="_blank">Instagram</a> • 
                    <a href={`mailto:${settingsData.contact_email}`}>Email</a>
                </p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>{settingsData.footer_text}</p>
        </div>
    </footer>
</body>
</html>
